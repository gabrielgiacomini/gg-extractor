# extractor configuration
# Copy to .env and edit. Values here are defaults; the skill always prompts to confirm.

# GitHub owner/org under which to create new skill repos.
GG_EXTRACTOR_GITHUB_OWNER=gg-skills

# Default repo visibility on creation. One of: private, public.
GG_EXTRACTOR_DEFAULT_VISIBILITY=private

# Default integration mode after extraction. One of: gitignore, submodule.
#   gitignore — leave the working tree in place, untrack from parent, add to parent .gitignore.
#   submodule — remove from parent, then `git submodule add` the new GitHub repo back at the same path.
GG_EXTRACTOR_DEFAULT_INTEGRATION=gitignore
